# ============================================================
#  STS2 Community Stats — Environment Configuration
#  Copy to .env and modify values
# ============================================================

# Database
DB_PASSWORD=your_strong_password_here
DATABASE_URL=postgresql://sts2stats:your_strong_password_here@db:5432/sts2stats

# Redis
REDIS_URL=redis://redis:6379/0

# API Server
HOST=0.0.0.0
PORT=8080
WORKERS=1
LOG_LEVEL=info

# Precompute
PRECOMPUTE_INTERVAL_MINUTES=10
CACHE_TTL_SECONDS=900

# Rate Limits
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_QUERY=60/minute

# Security (comma-separated mod versions to block)
BLOCKED_MOD_VERSIONS=
